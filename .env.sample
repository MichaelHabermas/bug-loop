# bug-loop environment — copy to .env and fill in. Bun auto-loads .env for all
# `bun run` commands; scripts/model-sweep.sh sources it for shell-level checks.
# .env is gitignored — never commit real keys.

# ── Required for open-model sweeps (Phase E) ────────────────────────────────
# OpenRouter API key (https://openrouter.ai/keys). Used by the OpenCode fixer
# runs and by the money-true cost telemetry (generation lookups).
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# Optional: override the OpenRouter API base (default https://openrouter.ai/api/v1)
# OPENROUTER_API_BASE=

# ── Worker selection (defaults shown; uncomment to override) ────────────────
# Fixer harness: codex | grok | opencode  (langgraph defaults codex; agent-sdk grok)
# BUGLOOP_FIXER=opencode
# Test-writer harness (tier-2 fallback behind manifest fixtures): grok | codex
# BUGLOOP_TESTWRITER=grok
# OpenRouter model for the OpenCode fixer (full id, e.g. openrouter/deepseek/deepseek-v4-pro)
# BUGLOOP_OPENCODE_MODEL=
# Claude Agent SDK triage model (agent-sdk pipeline unknowns tier)
# BUGLOOP_TRIAGE_MODEL=sonnet
# Codex fixer model override (e.g. gpt-5.6-luna)
# BUGLOOP_CODEX_MODEL=
# Grok fixer effort: low | medium | high | xhigh | max
# BUGLOOP_GROK_EFFORT=

# ── Pipeline/run knobs ───────────────────────────────────────────────────────
# Which pipeline the sweep rows run: agent-sdk | langgraph (sweep sets per row)
# BUGLOOP_PIPELINE=
# Service base URL for reproduction requests
# BUGLOOP_BASE_URL=http://127.0.0.1:3000
# Force dry-run of all GitHub/git mutations regardless of flags (1 = on)
# DRY_RUN=

# ── Watch daemon timing (ms) ─────────────────────────────────────────────────
# BUGLOOP_WATCH_POLL_MS=15000
# BUGLOOP_WATCH_DEBOUNCE_MS=5000
# BUGLOOP_WATCH_HEARTBEAT_MS=60000

# ── Benchmark meta-tests (repro-fires assertions on buggy code) ─────────────
# BUGLOOP_BENCH=1
