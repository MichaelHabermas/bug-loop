{
  "name": "bug-loop",
  "private": true,
  "workspaces": ["apps/*", "packages/*", "pipelines/*"],
  "scripts": {
    "typecheck": "tsc -b",
    "test": "bun test",
    "test:bench": "BUGLOOP_BENCH=1 bun test ./bench/seeded-bugs/repro-fires.test.ts",
    "trace:example": "bun run packages/core/scripts/generate-example-trace.ts",
    "publish:traces": "bun run scripts/publish-traces.ts",
    "pipeline:langgraph": "bun run pipelines/langgraph/src/index.ts",
    "pipeline:agent-sdk": "bun run pipelines/agent-sdk/src/index.ts",
    "service": "bun run apps/leaky-service/src/server.ts",
    "traffic": "bun run apps/leaky-service/scripts/traffic.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}
